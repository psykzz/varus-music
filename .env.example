# Copy this file to .env and adjust values before running docker compose.

# ── Database ──────────────────────────────────────────────────────────────────
# Password for the PostgreSQL 'varus' user
POSTGRES_PASSWORD=varus_music_secret

# ── Backend ───────────────────────────────────────────────────────────────────
# Secret used to sign JWT tokens - CHANGE THIS in production
JWT_SECRET=varus-music-dev-secret-change-in-production

# Host port the backend API is exposed on (default: 3001)
BACKEND_PORT=3001

# ── Storage volumes ───────────────────────────────────────────────────────────
# Absolute or relative host paths that are bind-mounted into the backend container.
# Change these to point at wherever you want to store / watch music on the host.
MUSIC_PATH=./storage/music
WATCH_PATH=./storage/watch

# ── Frontend ──────────────────────────────────────────────────────────────────
# Host port the frontend (nginx) is exposed on (default: 80)
FRONTEND_PORT=80
