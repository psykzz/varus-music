DATABASE_URL="file:./dev.db"
PORT=3001

# JWT secret — change this to a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret

# Last.fm API key — https://www.last.fm/api/account/create
LASTFM_API_KEY=

# Audio storage (defaults to backend/storage/music if not set — must be absolute)
# MUSIC_STORAGE_PATH=/absolute/path/to/storage/music

# Watch folder for auto-ingesting audio files (defaults to backend/storage/watch)
# WATCH_FOLDER=/absolute/path/to/watch
