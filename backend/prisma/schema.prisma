// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(cuid())
  username           String   @unique
  passwordHash       String
  onboardingComplete Boolean  @default(false)
  createdAt          DateTime @default(now())

  ratings       Rating[]
  cadenceSettings CadenceSetting[]
  playlists     PlaylistCycle[]
  downloadJobs  DownloadJob[]
}

model Track {
  id           String   @id @default(cuid())
  title        String
  artist       String
  album        String?
  filename     String   @unique
  duration     Int?     // duration in seconds
  mimeType     String   @default("audio/mpeg")
  albumArtUrl  String?
  genre        String?
  year         Int?
  lastfmUrl    String?
  playCount    Int      @default(0)  // incremented on natural completion (no skip)
  filePurged   Boolean  @default(false) // true when the audio file has been deleted from disk
  sourceUrl    String?  // original download URL for re-fetching purged files
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ratings      Rating[]
  cycles       PlaylistCycleTrack[]
  downloadJobs DownloadJob[]
}

model Rating {
  id        String   @id @default(cuid())
  userId    String
  trackId   String
  value     Int      // 1 = like, -1 = dislike, 0 = neutral
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  track     Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([userId, trackId])
}

model CadenceSetting {
  id        String   @id @default(cuid())
  userId    String
  interval  String   @default("weekly") // daily | weekly | monthly
  lastRun   DateTime?
  nextRun   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
}

model PlaylistCycle {
  id        String   @id @default(cuid())
  userId    String
  startedAt DateTime @default(now())
  expiresAt DateTime
  active    Boolean  @default(true)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tracks    PlaylistCycleTrack[]
}

model PlaylistCycleTrack {
  id        String   @id @default(cuid())
  cycleId   String
  trackId   String
  position  Int

  cycle     PlaylistCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  track     Track         @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([cycleId, trackId])
  @@unique([cycleId, position])
}

model DownloadJob {
  id        String   @id @default(cuid())
  userId    String
  url       String
  title     String?
  artist    String?
  status    String   @default("pending") // pending | downloading | done | error
  error     String?
  trackId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  track     Track?   @relation(fields: [trackId], references: [id])
}
